---
import Base from '../layouts/Base.astro';
import { DEVICES } from '../data/devices';
import { Board } from '../components/Board';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DeviceLab',
  url: Astro.site?.toString() ?? 'https://tigges.github.io/devicelab/',
};
---

<Base
  title="DeviceLab — Tune-your-own device rankings"
  description="Independent, deterministic rankings of laptops, tablets and desktop PCs. Weight the axes that matter."
  jsonLd={jsonLd}
>
  <Board client:load devices={DEVICES} />
</Base>
