---
import Base from '../layouts/Base.astro';
import { PRESETS } from '../data/presets';
import { DEVICES } from '../data/devices';
import { Board } from '../components/Board';
import { rankDevices } from '../lib/scoring';

export function getStaticPaths() {
  return PRESETS.map((preset) => ({
    params: { preset: preset.slug },
    props: { preset },
  }));
}

const { preset } = Astro.props as { preset: import('../data/schema').Preset };

// Scope the device pool by category. `'all'` presets show everything.
const pool =
  preset.category === 'all' ? DEVICES : DEVICES.filter((d) => d.category === preset.category);

const ranked = rankDevices(pool, preset.weights);
const top3 = ranked.slice(0, 3);

// ItemList structured data — helps this page qualify for rich results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: preset.title,
  description: preset.metaDescription,
  itemListElement: ranked.slice(0, 10).map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`/device/${r.device.id}`, Astro.site ?? Astro.url).toString(),
    name: r.device.name,
  })),
};
---

<Base
  title={preset.metaTitle}
  description={preset.metaDescription}
  jsonLd={jsonLd}
>
  <section class="container page-header">
    <div class="eyebrow">
      PRESET / {preset.category.toUpperCase()}
    </div>
    <h1>{preset.title}</h1>
    <p class="blurb">{preset.blurb}</p>
    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 18px;">
      {top3.map((r, i) => (
        <a
          href={`/device/${r.device.id}`}
          class="chip"
          data-accent="true"
          style="border-color: var(--accent); color: var(--ink);"
        >
          #{i + 1} {r.device.name} · {r.score.toFixed(1)}
        </a>
      ))}
    </div>
  </section>

  <Board
    client:load
    devices={pool}
    category={preset.category === 'all' ? 'all' : preset.category}
    initialWeights={preset.weights}
    presets={PRESETS}
    activePresetSlug={preset.slug}
    headline={preset.title.toUpperCase()}
  />

  <section class="container" style="padding: 40px 0;">
    <h2>Methodology</h2>
    <p style="color: var(--ink-2); max-width: 62ch;">
      Every device is scored on seven axes (performance, battery, display,
      portability, build, camera, value) on a 0–100 scale. The composite
      score is a weighted mean; nothing about the ranking depends on
      monetisation. Open the mixer to change the weights — the URL updates so
      you can share the exact ranking you're looking at.
    </p>
  </section>
</Base>
