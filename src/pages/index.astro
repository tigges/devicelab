---
import Base from '../layouts/Base.astro';
import { DEVICES } from '../data/devices';
import { Board } from '../components/Board';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DeviceLab',
  url: Astro.site?.toString() ?? 'https://tigges.github.io/devicelab/',
};
---

<Base
  title="DeviceLab — Tune-your-own device rankings"
  description="Independent, deterministic rankings of laptops, tablets and desktop PCs. Weight the axes that matter."
  jsonLd={jsonLd}
>
  <section class="dl-page-header">
    <div class="dl-eyebrow-hero">DEVICELAB / LEADERBOARD</div>
    <h1>The device leaderboard <br />you can weigh yourself.</h1>
    <p class="dl-blurb">
      No sponsored order. Six axes, deterministic scoring, and a mixer that
      recomputes the board instantly.
    </p>
  </section>

  <Board client:load devices={DEVICES} />
</Base>
