---
import '../styles/global.css';
import { DEVICES } from '../data/devices';
import { href } from '../lib/href';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  jsonLd?: unknown;
}

const {
  title,
  description = 'DeviceLab — deterministic device rankings you can tune.',
  canonical,
  jsonLd,
} = Astro.props;

const canonicalHref = canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const totalDevices = DEVICES.length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#FF5C00" />
    <link rel="icon" href={href('/favicon.svg')} type="image/svg+xml" />
    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    <header class="dl-site-header">
      <a class="dl-logo" href={href('/')}>DEVICE<span class="accent">LAB</span></a>
      <nav class="dl-nav">
        <a href={href('/best-laptops-for-students')}>Laptops</a>
        <a href={href('/best-tablets-for-drawing')}>Tablets</a>
        <a href={href('/best-gaming-pcs')}>PCs</a>
        <a href={href('/about')}>About</a>
      </nav>
      <span class="dl-tagline">{totalDevices} ranked · live scores</span>
    </header>
    <main>
      <slot />
    </main>
    <footer class="dl-site-footer">
      <span>© DeviceLab · Deterministic scoring · Independent</span>
      <span>v0.3 · prototype port</span>
    </footer>
  </body>
</html>
