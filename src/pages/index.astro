---
import Base from '../layouts/Base.astro';
import { PRESETS } from '../data/presets';
import { DEVICES } from '../data/devices';
import { Board } from '../components/Board';
import { href } from '../lib/href';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DeviceLab',
  url: Astro.site?.toString() ?? 'https://tigges.github.io/devicelab/',
};
---

<Base
  title="DeviceLab — Tune-your-own device rankings"
  description="Independent, deterministic rankings of laptops, phones, and tablets. Weight the axes that matter."
  jsonLd={jsonLd}
>
  <section class="container page-header">
    <div class="eyebrow">DEVICELAB / LEADERBOARD</div>
    <h1>The device leaderboard <br />you can weigh yourself.</h1>
    <p class="blurb">
      No sponsored order. Six axes, deterministic scoring, and a mixer that
      recomputes the board instantly.
    </p>
  </section>

  <Board
    client:load
    devices={DEVICES}
    presets={PRESETS}
  />

  <section class="container" style="padding: 24px 0 20px;">
    <h2 style="margin-bottom: 8px;">SEO landing pages</h2>
    <p style="color: var(--ink-3); margin-top: 0;">
      Each of these presets is a fixed URL that preloads a persona and category filter.
    </p>
    <div class="preset-grid">
      {PRESETS.map((preset) => (
        <a class="preset-card" href={href(`/${preset.slug}`)}>
          <div class="cat">{preset.category.toUpperCase()}</div>
          <h3>{preset.title}</h3>
          <p>{preset.blurb}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
