---
import '../styles/global.css';
import { DEVICES } from '../data/devices';
import { href } from '../lib/href';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  jsonLd?: unknown;
}

const {
  title,
  description = 'DeviceLab — deterministic device rankings you can tune.',
  canonical,
  jsonLd,
} = Astro.props;

const canonicalHref = canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const totalDevices = DEVICES.length;

// Category tabs live in the site header now (nav-class taxonomy, not a
// filter chip). The `key` is what gets written to `?cat=` and consumed
// by the Board island; the label is what the user sees.
const CATS = [
  { key: 'All', label: 'All' },
  { key: 'Laptop', label: 'Laptop' },
  { key: 'Tablet', label: 'Tablet' },
  { key: 'Desktop', label: 'PC' },
];

// href for a category link. From the homepage this becomes a soft-nav
// (intercepted below); from any other page it's a real link back to
// `/` with the `?cat=` seed.
const catHref = (key: string) =>
  key === 'All' ? href('/') : href(`/?cat=${encodeURIComponent(key)}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#FF5C00" />
    <link rel="icon" href={href('/favicon.svg')} type="image/svg+xml" />
    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    <header class="dl-site-header">
      <div class="dl-header-top">
        <a class="dl-logo" href={href('/')}>DEVICE<span class="accent">LAB</span></a>
        <span class="dl-tagline">{totalDevices} ranked · live scores</span>
      </div>
      <nav class="dl-header-nav" aria-label="Category">
        {CATS.map((c) => (
          <a class="dl-nav-cat" data-cat={c.key} href={catHref(c.key)}>
            {c.label}
          </a>
        ))}
        <a class="dl-nav-about" href={href('/about')}>About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="dl-site-footer">
      <div class="dl-footer-brand">
        <span>© DeviceLab · Independent, unpaid rankings</span>
      </div>
      <nav class="dl-footer-nav" aria-label="Site links">
        <a href={href('/about')}>About</a>
        <span aria-hidden>·</span>
        <a href={href('/disclosure')}>Disclosure</a>
        <span aria-hidden>·</span>
        <a href={href('/privacy')}>Privacy</a>
        <span aria-hidden>·</span>
        <a href={href('/terms')}>Terms</a>
        <span aria-hidden>·</span>
        <a href={href('/contact')}>Contact</a>
      </nav>
      <div class="dl-footer-meta">
        <span>v0.5</span>
      </div>
    </footer>

    <script is:inline>
      // Header category tabs — active-state sync + soft-nav on the
      // homepage. Runs once per page load; the Board island dispatches
      // `dl-cat-change` when it mutates category so this stays in sync
      // without a full-blown state broker.
      (() => {
        const tabs = document.querySelectorAll('.dl-nav-cat');
        if (!tabs.length) return;

        function currentCat() {
          const params = new URLSearchParams(location.search);
          return params.get('cat') || 'All';
        }

        function paint() {
          const cat = currentCat();
          tabs.forEach((el) => {
            el.setAttribute('data-active', el.dataset.cat === cat ? 'true' : 'false');
          });
        }
        paint();

        // Only intercept clicks on the page that hosts the Board — the
        // presence of `.dl-root` is the cheap, deployment-agnostic
        // marker (no need to know the base path).
        function isBoardPage() {
          return !!document.querySelector('.dl-root');
        }
        tabs.forEach((el) => {
          el.addEventListener('click', (e) => {
            if (!isBoardPage()) return;
            e.preventDefault();
            const cat = el.dataset.cat || 'All';
            const url = new URL(location.href);
            if (cat === 'All') url.searchParams.delete('cat');
            else url.searchParams.set('cat', cat);
            history.pushState(null, '', url.toString());
            window.dispatchEvent(new CustomEvent('dl-cat-change', { detail: { cat } }));
          });
        });

        window.addEventListener('popstate', paint);
        window.addEventListener('dl-cat-change', paint);
      })();
    </script>
  </body>
</html>
