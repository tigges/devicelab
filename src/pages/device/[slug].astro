---
import Base from '../../layouts/Base.astro';
import { DEVICES, slugify } from '../../data/devices';
import { AXIS_META } from '../../data/schema';
import { LINES } from '../../data/lines';
import { defaultOffers } from '../../data/merchants';
import { formatGBP } from '../../lib/format';
import { rankDevices } from '../../lib/scoring';
import { personaById } from '../../data/personas';
import { urgencyFor } from '../../lib/urgency';
import { TrackPriceForm } from '../../components/TrackPriceForm';
import { href } from '../../lib/href';

export function getStaticPaths() {
  return DEVICES.map((device) => ({
    params: { slug: slugify(device) },
    props: { device },
  }));
}

const { device } = Astro.props as { device: import('../../data/schema').Device };
const overall = personaById('Overall')!;
const peers = DEVICES.filter((d) => d.cat === device.cat);
const ranking = rankDevices(peers, overall.weights).find((r) => r.device.id === device.id);
const lineMeta = device.line ? LINES[device.brand]?.[device.line] : undefined;
const offers = defaultOffers(device);
const u = urgencyFor(device);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: device.name,
  brand: { '@type': 'Brand', name: device.brand },
  category: device.cat,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'GBP',
    price: device.price,
    availability: 'https://schema.org/InStock',
    url: new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString(),
  },
};

const clickApiPath = href('/api/track-click');
---

<Base
  title={`${device.name} — DeviceLab`}
  description={`${device.brand} ${device.line ? '· ' + device.line : ''} · ${device.cat}. Scored on 6 axes, ranked against ${peers.length - 1} peers.`}
  jsonLd={jsonLd}
>
  <section class="dl-page-header">
    <div class="dl-eyebrow-hero">
      {device.cat.toUpperCase()} / {device.brand.toUpperCase()}
      {device.line && ` · ${device.line.toUpperCase()}`}
    </div>
    <h1>{device.name}</h1>
    {lineMeta && (
      <p class="dl-blurb"><strong>{device.line}:</strong> {lineMeta.desc}</p>
    )}
    {(u.showDropPill || u.atLow) && (
      <div class="dl-urgency dl-urgency--hero" style="margin-top: 10px;">
        {u.drop > 0 && (
          <span class="dl-urgency-drop">▼{formatGBP(u.drop)}</span>
        )}
        {u.atLow && <span class="dl-urgency-low">8-WK LOW</span>}
      </div>
    )}
  </section>

  <div class="dl-device-meta">
    <div>
      <div class="k">Composite (equal wts)</div>
      <div class="v">{ranking?.score.toFixed(1) ?? '—'}</div>
    </div>
    <div>
      <div class="k">Category rank</div>
      <div class="v">#{ranking?.rank ?? '—'} of {peers.length}</div>
    </div>
    <div>
      <div class="k">Ecosystem</div>
      <div class="v">{device.eco}</div>
    </div>
    <div>
      <div class="k">Typical price</div>
      <div class="v">{formatGBP(device.price)}</div>
    </div>
  </div>

  <section class="dl-container" style="padding: 20px 16px 8px;">
    <h2 style="margin-bottom: 6px;">Axis scores</h2>
    <div class="dl-axis-list" style="padding: 8px 0;">
      {AXIS_META.map((a) => (
        <div class="dl-axis-row">
          <div class="label">{a.full}</div>
          <div class="bar"><span style={`width: ${device[a.key]}%`}></span></div>
          <div class="val">{device[a.key]}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="dl-container" style="padding: 8px 16px 20px;">
    <h2 style="margin-bottom: 8px;">Where to buy</h2>
    <div class="dl-buy" data-device-id={device.id}>
      {offers.map((o) => (
        <a
          class={`dl-buy-btn ${o.primary ? 'dl-buy-btn--primary' : 'dl-buy-btn--ghost'}`}
          href={o.url}
          rel="sponsored noopener"
          target="_blank"
          data-merchant-slug={o.merchantSlug}
        >
          {o.merchant} →
        </a>
      ))}
    </div>
    <p class="dl-disclosure">
      ↗ Retail links may earn us a commission. This never affects scores or ranking — offers are sorted by price only.
    </p>
  </section>

  <section class="dl-container" style="padding: 8px 16px 20px;">
    <h2 style="margin-bottom: 8px;">Track price</h2>
    <p style="color: #5F6368; margin: 4px 0 12px; font-size: 13px;">
      Get one email when this device hits your target. No newsletter.
    </p>
    <TrackPriceForm client:idle deviceId={String(device.id)} device={device} />
  </section>

  <section class="dl-container" style="padding: 8px 16px 20px;">
    <h2 style="margin-bottom: 8px;">Pairs well with</h2>
    <div class="dl-pairs">
      {device.pairs.map((pr) => <div class="dl-pair-card">{pr}</div>)}
    </div>
  </section>
</Base>

<script is:inline define:vars={{ clickApiPath, deviceId: device.id }}>
  // Delegated outbound-click tracker for the static device page. Uses
  // sendBeacon so navigation isn't blocked.
  (() => {
    const buy = document.querySelector('.dl-buy[data-device-id]');
    if (!buy) return;
    buy.addEventListener('click', (e) => {
      const a = e.target.closest('a[data-merchant-slug]');
      if (!a) return;
      const payload = JSON.stringify({
        deviceId,
        merchantSlug: a.dataset.merchantSlug,
        source: 'device-page',
        personaId: null,
        category: null,
        ts: Date.now(),
        path: window.location.pathname,
      });
      try {
        if ('sendBeacon' in navigator) {
          navigator.sendBeacon(clickApiPath, new Blob([payload], { type: 'application/json' }));
        } else {
          fetch(clickApiPath, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true,
          }).catch(() => {});
        }
      } catch { /* noop */ }
    });
  })();
</script>
